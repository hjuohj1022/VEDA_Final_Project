# ================================
# 백엔드 API 서버
# ================================
# 로그인/녹화목록/파일관리 API 주소
API_URL=https://your-api-host
# 로그인 요청 타임아웃(ms)
LOGIN_TIMEOUT_MS=12000
# API HTTPS 인증서 경로
SSL_CA_CERT=certs/rootCA.crt
SSL_CLIENT_CERT=certs/client-qt.crt
SSL_CLIENT_KEY=certs/client-qt.key
# 서버 인증서 검증 여부 (1: 검증, 0: 미검증)
SSL_VERIFY_PEER=1
# SSL 에러 무시 여부 (1: 무시, 0: 미무시)
SSL_IGNORE_ERRORS=0

# ================================
# RTSP (MediaMTX)
# ================================
# MediaMTX 서버 IP 또는 도메인
RTSP_IP=your-mediamtx-host
# RTSP 스킴 (rtsp 또는 rtsps)
RTSP_SCHEME=rtsps
# MediaMTX 서버 포트
RTSP_PORT=8555
# RTSP 읽기 계정 (MediaMTX pathDefaults 인증)
RTSP_USERNAME=your-rtsp-user
RTSP_PASSWORD=your-rtsp-password
# 메인/서브 스트림 경로 템플릿 ({index}: 0~3)
RTSP_MAIN_PATH_TEMPLATE=/{index}/main
RTSP_SUB_PATH_TEMPLATE=/{index}/sub
# 필요 시 프로파일 번호 매핑에 사용
RTSP_MAIN_PROFILE=1
RTSP_SUB_PROFILE=2

# ================================
# MQTT
# ================================
# MQTT 브로커 주소/포트
MQTT_HOST=your-mqtt-broker-host
MQTT_PORT=8883
# TLS 사용 여부 (1: 사용, 0: 미사용)
MQTT_USE_TLS=1
# MQTT 기능 사용 여부 (1: 사용, 0: 미사용)
MQTT_ENABLED=0
# TLS 인증서/키 경로
MQTT_CA_CERT=certs/rootCA.crt
MQTT_CLIENT_CERT=certs/client-qt.crt
MQTT_CLIENT_KEY=certs/client-qt.key

# 관리자 잠금 해제 코드
ADMIN_UNLOCK_KEY=your-admin-unlock-key

# ================================
# SUNAPI 카메라 제어
# ================================
# 카메라 제어 프로토콜 (http 또는 https)
SUNAPI_SCHEME=http
# 실제 카메라 IP (MediaMTX 아님)
SUNAPI_IP=your-camera-ip
# SUNAPI 포트 (http: 80, https: 443)
SUNAPI_PORT=80
# 카메라 로그인 계정
SUNAPI_USER=your-camera-user
SUNAPI_PASSWORD=your-camera-password
# 프로파일 전환 시 함께 적용할 기본 프로파일
SUNAPI_NETWORK_PROFILE=1
SUNAPI_RECORD_PROFILE=2
# Playback RTSP 포트
SUNAPI_RTSP_PORT=554

# ================================
# Playback StreamingServer (역분석/테스트)
# ================================
# 1이면 playback 준비 완료 후 ws://<SUNAPI_IP>/StreamingServer 자동 연결
PLAYBACK_WS_AUTO_CONNECT=1
# 1이면 WS RTSP 시퀀스 DESCRIBE 요청 포함(장비별 호환 이슈로 기본 0 권장)
PLAYBACK_WS_SEND_DESCRIBE=0
# digestauth 2단계 응답값 비어 있을 때 사용할 고정값(옵션)
PLAYBACK_WS_DIGEST_RESPONSE=
# 연결 직후 보낼 첫 바이너리 프레임(hex, 공백 허용). 비워두면 전송 안 함.
PLAYBACK_WS_HEX1=
# 추가 바이너리 프레임(옵션)
PLAYBACK_WS_HEX2=
PLAYBACK_WS_HEX3=
# 로컬 SDP URL 형식 강제 토글(0: file:///, 1: file:/)
PLAYBACK_WS_SDP_FILE_PROTOCOL=0

