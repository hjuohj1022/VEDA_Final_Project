# ================================
# 백엔드 API 서버 설정
# ================================
# 로그인/녹화목록/파일관리 API 주소
API_URL=http://your-api-server:8080
# 로그인 요청 타임아웃(ms)
LOGIN_TIMEOUT_MS=12000
# API HTTPS 인증서 경로 (미설정 시 MQTT_* 경로 재사용)
SSL_CA_CERT=certs/rootCA.crt
SSL_CLIENT_CERT=certs/client-qt.crt
SSL_CLIENT_KEY=certs/client-qt.key
# 서버 인증서 검증 여부 (1: 검증, 0: 미검증)
SSL_VERIFY_PEER=1
# SSL 에러 무시 여부 (1: 무시, 0: 미무시)
SSL_IGNORE_ERRORS=0

# ================================
# RTSP (MediaMTX) 설정
# ================================
# MediaMTX 서버 IP 또는 도메인
RTSP_IP=your-mediamtx-host
# MediaMTX 서버 포트
RTSP_PORT=8555
# 메인/서브 스트림 경로 템플릿 ({index}: 0~3)
RTSP_MAIN_PATH_TEMPLATE=/{index}/main
RTSP_SUB_PATH_TEMPLATE=/{index}/sub
# 필요 시 프로파일 번호 매핑에 사용
RTSP_MAIN_PROFILE=1
RTSP_SUB_PROFILE=2

# ================================
# MQTT 설정
# ================================
# MQTT 브로커 주소/포트
MQTT_HOST=your-mqtt-broker-host
MQTT_PORT=8883
# TLS 사용 여부 (1: 사용, 0: 미사용)
MQTT_USE_TLS=1
# MQTT 기능 사용 여부 (1: 사용, 0: 미사용)
MQTT_ENABLED=0
# TLS 인증서/키 경로
MQTT_CA_CERT=certs/rootCA.crt
MQTT_CLIENT_CERT=certs/client-qt.crt
MQTT_CLIENT_KEY=certs/client-qt.key

# 관리자 잠금 해제 코드
ADMIN_UNLOCK_KEY=your-admin-unlock-key

# ================================
# SUNAPI 카메라 제어
# ================================
# 카메라 제어 프로토콜 (http 또는 https)
SUNAPI_SCHEME=http
# 실제 카메라 IP (MediaMTX 아님)
SUNAPI_IP=your-camera-ip
# SUNAPI 포트 (http: 80, https: 443)
SUNAPI_PORT=80
# 카메라 로그인 계정
SUNAPI_USER=your-camera-user
SUNAPI_PASSWORD=your-camera-password
# 프로파일 전환 시 함께 적용할 기본 프로파일
SUNAPI_NETWORK_PROFILE=1
SUNAPI_RECORD_PROFILE=2
