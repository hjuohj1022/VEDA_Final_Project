# ================================
# 백엔드 API
# ================================
API_URL=https://your-api-host
LOGIN_TIMEOUT_MS=12000
REGISTER_TIMEOUT_MS=12000

# API/mTLS
SSL_CA_CERT=certs/rootCA.crt
SSL_CLIENT_CERT=certs/client-qt.crt
SSL_CLIENT_KEY=certs/client-qt.key
SSL_VERIFY_PEER=1
SSL_IGNORE_ERRORS=0

# ================================
# RTSP (Live / MediaMTX)
# ================================
RTSP_IP=your-mediamtx-host
RTSP_SCHEME=rtsps
RTSP_PORT=8555
RTSP_USERNAME=your-rtsp-user
RTSP_PASSWORD=your-rtsp-password
RTSP_MAIN_PATH_TEMPLATE=/{index}/main
RTSP_SUB_PATH_TEMPLATE=/{index}/sub
RTSP_MAIN_PROFILE=1
RTSP_SUB_PROFILE=2

# ================================
# MQTT (선택)
# ================================
MQTT_ENABLED=0
MQTT_HOST=your-mqtt-broker-host
MQTT_PORT=8883
MQTT_USE_TLS=1
MQTT_CA_CERT=certs/rootCA.crt
MQTT_CLIENT_CERT=certs/client-qt.crt
MQTT_CLIENT_KEY=certs/client-qt.key
# 필요 시 사용
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DETECTED_TOPIC=
MQTT_STATUS_TOPIC=

# 관리자 잠금 해제
ADMIN_UNLOCK_KEY=your-admin-unlock-key

# ================================
# SUNAPI / Playback / Export
# ================================
SUNAPI_SCHEME=https
SUNAPI_IP=your-nginx-gateway-host
SUNAPI_PORT=443

# 아직 일부 경로에서 사용(완전 Crow API 전환 전)
SUNAPI_USER=your-camera-user
SUNAPI_PASSWORD=your-camera-password

# RTSP challenge 대상 카메라 호스트
SUNAPI_RTSP_HOST=your-camera-host
SUNAPI_RTSP_PORT=554

# Storage 조회(장비별 상이할 수 있음)
SUNAPI_STORAGE_CGI=recording.cgi
SUNAPI_STORAGE_SUBMENU=storage
SUNAPI_STORAGE_ACTION=view
SUNAPI_STORAGE_QUERY=

# SUNAPI export CGI 후보(장비별 상이)
SUNAPI_EXPORT_CREATE_CGI=recording.cgi
SUNAPI_EXPORT_CREATE_SUBMENU=export
SUNAPI_EXPORT_CREATE_ACTION=create
SUNAPI_EXPORT_CREATE_QUERY=
SUNAPI_EXPORT_POLL_CGI=recording.cgi
SUNAPI_EXPORT_POLL_SUBMENU=export
SUNAPI_EXPORT_POLL_ACTION=status
SUNAPI_EXPORT_POLL_QUERY=
SUNAPI_EXPORT_DOWNLOAD_CGI=recording.cgi
SUNAPI_EXPORT_DOWNLOAD_SUBMENU=export
SUNAPI_EXPORT_DOWNLOAD_ACTION=download
SUNAPI_EXPORT_DOWNLOAD_QUERY=
SUNAPI_EXPORT_TYPE=AVI
SUNAPI_EXPORT_POLL_INTERVAL_MS=1500
SUNAPI_EXPORT_POLL_TIMEOUT_MS=120000

# 608 장비에서 ffmpeg 우회 경로 사용 여부
# 0: 바로 WS export, 1: ffmpeg 백업 먼저 시도
PLAYBACK_EXPORT_USE_FFMPEG_BACKUP=0
PLAYBACK_EXPORT_FFMPEG_TIMEOUT_MS=20000
PLAYBACK_EXPORT_FFMPEG_PATH=

# Playback WS
PLAYBACK_WS_AUTO_CONNECT=1
SUNAPI_STREAMING_WS_PATH=/sunapi/StreamingServer
PLAYBACK_WS_SEND_DESCRIBE=0
PLAYBACK_WS_DIGEST_RESPONSE=
PLAYBACK_WS_SDP_FILE_PROTOCOL=0
