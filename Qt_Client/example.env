# ================================
# 백엔드 API 서버
# ================================
# 로그인/녹화목록/파일관리 API 주소
API_URL=https://your-api-host
# 로그인 요청 타임아웃(ms)
LOGIN_TIMEOUT_MS=12000
# 회원가입 요청 타임아웃(ms)
REGISTER_TIMEOUT_MS=12000
# API HTTPS 인증서 경로 (미설정 시 MQTT_* 경로 재사용)
SSL_CA_CERT=certs/rootCA.crt
SSL_CLIENT_CERT=certs/client-qt.crt
SSL_CLIENT_KEY=certs/client-qt.key
# 서버 인증서 검증 여부 (1: 검증, 0: 미검증)
SSL_VERIFY_PEER=1
# SSL 에러 무시 여부 (1: 무시, 0: 미무시)
SSL_IGNORE_ERRORS=0

# ================================
# RTSP (MediaMTX)
# ================================
# MediaMTX 서버 IP
RTSP_IP=your-mediamtx-host
# RTSP 스킴 (rtsp 또는 rtsps)
RTSP_SCHEME=rtsps
# MediaMTX 서버 포트
RTSP_PORT=8555
# RTSP 읽기 계정 (MediaMTX pathDefaults 인증)
RTSP_USERNAME=your-rtsp-user
RTSP_PASSWORD=your-rtsp-password
# 메인/서브 스트림 경로 템플릿 ({index}: 0~3)
RTSP_MAIN_PATH_TEMPLATE=/{index}/main
RTSP_SUB_PATH_TEMPLATE=/{index}/sub
# 필요 시 프로파일 번호 매핑에 사용
RTSP_MAIN_PROFILE=1
RTSP_SUB_PROFILE=2

# ================================
# MQTT
# ================================
# MQTT 브로커 주소/포트
MQTT_HOST=your-mqtt-broker-host
MQTT_PORT=8883
# TLS 사용 여부 (1: 사용, 0: 미사용)
MQTT_USE_TLS=1
# MQTT 기능 사용 여부 (1: 사용, 0: 미사용)
MQTT_ENABLED=1
MQTT_THERMAL_TOPIC=lepton/frame/chunk
# TLS 인증서/키 경로
MQTT_CA_CERT=certs/rootCA.crt
MQTT_CLIENT_CERT=certs/client-qt.crt
MQTT_CLIENT_KEY=certs/client-qt.key

# 관리자 잠금 해제 코드
ADMIN_UNLOCK_KEY=your-admin-unlock-key

# ================================
# SUNAPI Playback/Export
# ================================
# Playback/Export 세션 API에 전달할 RTSP 포트
SUNAPI_RTSP_PORT=554
# WS 경로 (Crow 세션 API 응답 WsPath 우선, 비어있을 때 fallback)
SUNAPI_STREAMING_WS_PATH=/sunapi/StreamingServer

# Playback Export 포맷/타이밍 제어
SUNAPI_EXPORT_TYPE=AVI
SUNAPI_EXPORT_POLL_INTERVAL_MS=1500
SUNAPI_EXPORT_POLL_TIMEOUT_MS=120000
# 608 장비에서 ffmpeg 백업 사용 (0: 비활성, 1: 활성)
PLAYBACK_EXPORT_USE_FFMPEG_BACKUP=0

# ================================
# Playback StreamingServer
# ================================
# 1: playback 준비 완료 후 Crow 세션 API 응답으로 WS 자동 연결
PLAYBACK_WS_AUTO_CONNECT=1
# 1: WS RTSP 시퀀스 DESCRIBE 포함(장비 호환 이슈로 기본 0 권장)
PLAYBACK_WS_SEND_DESCRIBE=0
# digest response 강제 설정(옵션, 비우면 자동)
PLAYBACK_WS_DIGEST_RESPONSE=
# 로컬 SDP URL 형식 강제 토글(0: file:///, 1: file:/)
PLAYBACK_WS_SDP_FILE_PROTOCOL=0
