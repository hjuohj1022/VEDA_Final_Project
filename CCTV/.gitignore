# ---------------------------
# Build artifacts / binaries
# ---------------------------
/build/
/build-*/
*.obj
*.lib
*.dll
*.pdb
*.ilk
*.tlog
*.exe

# ---------------------------
# CMake / Visual Studio
# ---------------------------
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.user

# Keep shared VSCode settings only
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json

# ---------------------------
# Local machine config (secrets/paths)
# ---------------------------
/config/local_paths.cmake
/config/app_config.h
/certs/

# ---------------------------
# External SDKs / downloaded deps
# ---------------------------
/opencv/
/TensorRT-*/
/_downloads/
/_tensorrt_extract/

# ---------------------------
# ML artifacts (large, regenerated)
# ---------------------------
/ml_assets/checkpoints/
/ml_assets/onnx/
/ml_assets/engines/
*.onnx
*.engine
*.pth
*.weights
*.safetensors

# ---------------------------
# Runtime logs / temp / cache
# ---------------------------
*.log
__pycache__/
*/__pycache__/
.ipynb_checkpoints/
*.pyc

# ---------------------------
# Backups / archives
# ---------------------------
*.bak
/archive/

# ---------------------------
# Large local assets
# ---------------------------
/assets/installers/
/assets/docs/*.pdf
*.png
tech.md
/ml_assets/sources/Depth-Anything-3
