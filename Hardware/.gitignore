# Hardware-wide ignore rules

# Python caches
__pycache__/
*.py[cod]

# Generic firmware/native build outputs
*.o
*.obj
*.elf
*.bin
*.hex
*.map
*.lst
*.su
*.d

# CMake / Ninja / Zephyr / MCUX generated files
build/
Debug/
Release/
debug/
release/
cmake-build-*/
flexspi_nor_debug/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
.ninja_deps
.ninja_log
rules.ninja
mcux_modules.txt
mcux_settings.txt
sysbuild_modules.txt
headers.txt
sources.txt

# Local tool metadata
.pio/
.west/

# Local editor-generated files
**/.vscode/.browse.c_cpp.db*
**/.vscode/c_cpp_properties.json
**/.vscode/launch.json
**/.vscode/ipch/

# ESP32 local secrets and generated config
esp32/certs/
esp32/main/certs/*.key
esp32/main/certs/*.pem
esp32/main/app_secrets.h
esp32/main/mqtt/app_client_config.py
RESULT.md
esp32/main/mqtt/result.md
esp32/main/secrets/
esp32/secrets/
esp32/.env
esp32/.env.*
esp32/*.local
esp32/*.secret
esp32/*.secrets
esp32/sdkconfig
esp32/sdkconfig.old
